.PHONY : test/test_resampling.s

# target to generate assembly for a file
test/test_resampling.cpp.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/test_resampling.dir/build.make CMakeFiles/test_resampling.dir/test/test_resampling.cpp.s
.PHONY : test/test_resampling.cpp.s

